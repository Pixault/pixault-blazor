@using Pixault.Client
@inject PixaultAdminClient Admin

<div>
    <div style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.5rem; font-weight: 700; margin: 0 0 0.25rem; color: #111827;">Plugin Marketplace</h2>
        <p style="color: #6b7280; margin: 0 0 1rem; font-size: 0.9rem;">Extend your image pipeline with powerful processing plugins</p>

        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <RadzenButton Text="All"
                          ButtonStyle="@(ActiveFilter == null ? ButtonStyle.Primary : ButtonStyle.Light)"
                          Size="ButtonSize.Small"
                          Style="border-radius: 9999px;"
                          Click="@(args => SetFilter(null))" />
            @foreach (var cat in Categories)
            {
                <RadzenButton Text="@cat"
                              ButtonStyle="@(ActiveFilter == cat ? ButtonStyle.Primary : ButtonStyle.Light)"
                              Size="ButtonSize.Small"
                              Style="border-radius: 9999px;"
                              Click="@(args => SetFilter(cat))" />
            }
        </div>
    </div>

    @if (Loading)
    {
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 3rem; color: #6b7280;">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
            <span>Loading plugins...</span>
        </div>
    }
    else if (Error is not null)
    {
        <div style="padding: 1.5rem; background: #fef2f2; border: 1px solid #fecaca; border-radius: 0.5rem; color: #dc2626; display: flex; align-items: center; gap: 1rem;">
            <span>Failed to load plugins: @Error</span>
            <RadzenButton Text="Retry"
                          ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small"
                          Click="@(args => LoadPluginsAsync())" />
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
            @foreach (var plugin in FilteredPlugins)
            {
                <RadzenCard Style="@($"padding: 1.25rem; {(plugin.IsActivated ? "border: 1px solid #6366f1; background: linear-gradient(135deg, #fefce8 0%, white 30%);" : "")}")">
                    <div style="display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.75rem;">
                        <span style="font-size: 1.75rem; line-height: 1; flex-shrink: 0;">@GetCategoryIcon(plugin.Category)</span>
                        <div style="flex: 1; min-width: 0;">
                            <h3 style="margin: 0; font-size: 1rem; font-weight: 600; color: #111827;">@plugin.DisplayName</h3>
                            <span style="font-size: 0.75rem; color: #9ca3af;">by @plugin.Vendor</span>
                        </div>
                        <RadzenBadge Text="@plugin.Stage"
                                     BadgeStyle="BadgeStyle.Info"
                                     Style="font-size: 0.7rem; white-space: nowrap;" />
                    </div>

                    <p style="font-size: 0.85rem; color: #4b5563; line-height: 1.5; margin: 0 0 0.75rem;">@plugin.Description</p>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                        <RadzenBadge Text="@plugin.Category"
                                     BadgeStyle="BadgeStyle.Light"
                                     Style="background: #ede9fe; color: #7c3aed; font-size: 0.75rem; font-weight: 500;" />
                        <span style="font-size: 0.85rem; font-weight: 600; color: #374151;">
                            @if (plugin.PriceCentsPerInvocation == 0)
                            {
                                <span style="color: #059669;">Free</span>
                            }
                            else
                            {
                                <span>@($"${plugin.PriceCentsPerInvocation / 100.0:F2}")/use</span>
                            }
                        </span>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <code style="font-size: 0.8rem; padding: 0.25rem 0.5rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 4px; color: #6366f1; font-family: 'SF Mono', Consolas, monospace;">@($"{plugin.UrlPrefix}_value")</code>
                    </div>

                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <RadzenSwitch Value="@plugin.IsActivated"
                                      Disabled="@Toggling.Contains(plugin.Name)"
                                      Change="@(val => TogglePluginAsync(plugin))" />
                        @if (plugin.IsActivated)
                        {
                            <span style="font-size: 0.8rem; font-weight: 500; color: #059669;">Active</span>
                        }
                        else
                        {
                            <span style="font-size: 0.8rem; font-weight: 500; color: #6b7280;">Inactive</span>
                        }
                    </div>
                </RadzenCard>
            }
        </div>

        @if (!FilteredPlugins.Any())
        {
            <div style="text-align: center; padding: 3rem; color: #9ca3af; font-size: 0.9rem;">No plugins found in this category.</div>
        }
    }
</div>
