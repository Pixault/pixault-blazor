@namespace Pixault.Blazor
@using Pixault.Client

<div style="display: flex; flex-direction: column; gap: 1.5rem; --pxlt-accent: @AccentColor; width: 100%; min-width: 0; overflow: hidden; box-sizing: border-box;">

    @* ── Header ── *@
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; min-width: 0;">
        <div style="display: flex; align-items: center; gap: 0.5rem; min-width: 0;">
            <h2 style="margin: 0; font-size: 1.25rem; font-weight: 600;">Images</h2>
            @if (_totalCount > 0)
            {
                <span style="background: rgba(6, 182, 212, 0.1); color: var(--pxlt-accent, #06b6d4); font-size: 0.75rem; font-weight: 600; padding: 0.125rem 0.5rem; border-radius: 999px;">
                    @_totalCount
                </span>
            }
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem; min-width: 0; flex: 1 1 0;">
            <RadzenTextBox @bind-Value="_searchTerm"
                           Placeholder="Search images..."
                           Change="@(async _ => await OnSearchChanged())"
                           Style="min-width: 0; width: 100%; max-width: 200px;" />
            <RadzenButton Icon="refresh"
                          ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small"
                          title="Refresh"
                          Click="@(args => LoadImagesAsync())" />
        </div>
    </div>

    @* ── Breadcrumb bar ── *@
    <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; min-width: 0;">
        <nav style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.8125rem; min-width: 0; overflow: hidden;">
            @{ var segments = BreadcrumbSegments; }
            @for (var i = 0; i < segments.Count; i++)
            {
                var seg = segments[i];
                var isLast = i == segments.Count - 1;
                if (i > 0)
                {
                    <span style="color: #94a3b8; margin: 0 0.125rem;">/</span>
                }
                @if (isLast)
                {
                    <span style="font-weight: 600; color: #0f172a; white-space: nowrap;">@seg.Name</span>
                }
                else
                {
                    <span style="cursor: pointer; color: var(--pxlt-accent, #06b6d4); white-space: nowrap; text-decoration: none;"
                          @onclick="() => NavigateToFolder(seg.Path)"
                          @onclick:preventDefault>@seg.Name</span>
                }
            }
        </nav>
        <div style="display: flex; align-items: center; gap: 0.375rem; flex-shrink: 0;">
            <RadzenButton Text="New Folder"
                          Icon="create_new_folder"
                          ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small"
                          Click="@(() => _creatingFolder = !_creatingFolder)" />
            <RadzenButton Text="@(_showUploadZone ? "Hide Upload" : "Upload")"
                          Icon="@(_showUploadZone ? "expand_less" : "cloud_upload")"
                          ButtonStyle="@(_showUploadZone ? ButtonStyle.Secondary : ButtonStyle.Light)"
                          Size="ButtonSize.Small"
                          Click="@(() => _showUploadZone = !_showUploadZone)" />
        </div>
    </div>

    @* ── Inline upload zone ── *@
    @if (_showUploadZone)
    {
        <div style="border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 1rem; background: #fafbfc;">
            <PixaultUploader Project="@Project"
                             AccentColor="@AccentColor"
                             InitialFolder="@_currentPath"
                             OnUploadComplete="@(async _ => await OnInlineUploadComplete())" />
        </div>
    }

    @* ── Grid ── *@
    @if (_loading)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; padding: 3rem 1rem; color: #6b7280;">
            <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Medium" />
            <span>Loading images...</span>
        </div>
    }
    else if (_error is not null)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; padding: 3rem 1rem; color: #dc2626;">
            <p style="margin: 0; font-size: 0.875rem;">@_error</p>
            <RadzenButton Text="Retry"
                          ButtonStyle="ButtonStyle.Secondary"
                          Size="ButtonSize.Small"
                          Click="@(args => LoadImagesAsync())"
                          Style="margin-top: 0.5rem;" />
        </div>
    }
    else if (_childFolders.Count == 0 && _filtered.Count == 0 && !_creatingFolder)
    {
        @* ── Empty state ── *@
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; padding: 3rem 1rem; color: #6b7280;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 style="width: 3rem; height: 3rem; opacity: 0.4;">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
            <p style="margin: 0; font-size: 0.875rem;">
                @if (!string.IsNullOrEmpty(_searchTerm))
                {
                    @:No images match your search
                }
                else
                {
                    @:This folder is empty
                }
            </p>
            <div style="display: flex; gap: 0.5rem; margin-top: 0.25rem;">
                <RadzenButton Text="Upload"
                              Icon="cloud_upload"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@(() => _showUploadZone = true)" />
                <RadzenButton Text="New Folder"
                              Icon="create_new_folder"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@(() => _creatingFolder = true)" />
            </div>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(160px, 100%), 1fr)); gap: 1rem;">

            @* ── New folder inline input ── *@
            @if (_creatingFolder)
            {
                <div style="border-radius: 0.5rem; border: 2px dashed var(--pxlt-accent, #06b6d4); overflow: hidden; background: #fafbfc; display: flex; flex-direction: column; align-items: center; justify-content: center; aspect-ratio: 1; padding: 1rem; gap: 0.5rem;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="var(--pxlt-accent, #06b6d4)" stroke-width="1.5"
                         style="width: 2rem; height: 2rem; opacity: 0.6;">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                        <line x1="12" y1="11" x2="12" y2="17" /><line x1="9" y1="14" x2="15" y2="14" />
                    </svg>
                    <input type="text" @bind="_newFolderName" @bind:event="oninput"
                           @onkeydown="OnFolderNameKeyDown"
                           placeholder="Folder name"
                           style="font-size: 0.8125rem; width: 100%; text-align: center; padding: 0.375rem 0.5rem; border: 1px solid #d1d5db; border-radius: 0.25rem; outline: none;" />
                    <div style="display: flex; gap: 0.25rem;">
                        <RadzenButton Icon="check" Size="ButtonSize.ExtraSmall"
                                      ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                      Click="@(args => CreateFolderAsync())" />
                        <RadzenButton Icon="close" Size="ButtonSize.ExtraSmall"
                                      ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                      Click="@(() => { _creatingFolder = false; _newFolderName = ""; })" />
                    </div>
                </div>
            }

            @* ── Folder cards ── *@
            @foreach (var folder in _childFolders)
            {
                var f = folder;
                <div style="border-radius: 0.5rem; border: 1px solid #e2e8f0; overflow: hidden; cursor: pointer; transition: box-shadow 0.15s, transform 0.15s; background: #fff; display: flex; flex-direction: column;"
                     @onclick="() => NavigateToFolder(f)">
                    <div style="aspect-ratio: 1; background: #f8fafc; display: flex; align-items: center; justify-content: center; position: relative;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"
                             style="width: 3.5rem; height: 3.5rem;">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                        </svg>
                        @* Delete button *@
                        <button type="button"
                                style="position: absolute; top: 0.25rem; right: 0.25rem; padding: 0.375rem; background: rgba(255,255,255,0.8); border: none; border-radius: 4px; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0.5; transition: opacity 0.15s;"
                                @onclick="() => _folderToDelete = f" @onclick:stopPropagation="true" @onclick:preventDefault="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 style="width: 0.875rem; height: 0.875rem; color: #6b7280; pointer-events: none;">
                                <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                            </svg>
                        </button>
                    </div>
                    <div style="padding: 0.625rem 0.75rem;">
                        <div style="font-size: 0.8125rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@f">
                            @ChildFolderDisplayName(f)
                        </div>
                        <div style="font-size: 0.6875rem; color: #94a3b8;">Folder</div>
                    </div>
                </div>
            }

            @* ── Image cards ── *@
            @foreach (var image in _filtered)
            {
                <div style="border-radius: 0.5rem; border: 1px solid #e2e8f0; overflow: hidden; cursor: pointer; transition: box-shadow 0.15s; background: #fff; @(image.ImageId == _selectedId ? $"box-shadow: 0 0 0 2px var(--pxlt-accent, #06b6d4);" : "")"
                     @onclick="() => SelectImage(image)">

                    <div style="position: relative; overflow: hidden; background-color: #f9fafb; background-image: linear-gradient(45deg, #e5e7eb 25%, transparent 25%), linear-gradient(-45deg, #e5e7eb 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #e5e7eb 75%), linear-gradient(-45deg, transparent 75%, #e5e7eb 75%); background-size: 16px 16px; background-position: 0 0, 0 8px, 8px -8px, -8px 0;">
                        @if (image.IsVideo)
                        {
                            <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(239, 68, 68, 0.85); color: white; font-size: 0.625rem; font-weight: 700; padding: 0.125rem 0.375rem; border-radius: 4px; letter-spacing: 0.05em; z-index: 1; display: inline-flex; align-items: center; gap: 0.25rem;">
                                <svg viewBox="0 0 24 24" fill="currentColor" style="width: 0.5rem; height: 0.5rem;">
                                    <polygon points="5,3 19,12 5,21" />
                                </svg>
                                VIDEO
                            </div>
                        }
                        else if (image.IsEps)
                        {
                            <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(22, 163, 74, 0.85); color: white; font-size: 0.625rem; font-weight: 700; padding: 0.125rem 0.375rem; border-radius: 4px; letter-spacing: 0.05em; z-index: 1;">EPS</div>
                        }
                        else if (image.IsSvg)
                        {
                            <div style="position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(0,0,0,0.6); color: white; font-size: 0.625rem; font-weight: 700; padding: 0.125rem 0.375rem; border-radius: 4px; letter-spacing: 0.05em; z-index: 1;">SVG</div>
                        }
                        <img src="@ThumbnailUrl(image)" alt="@(image.Name ?? image.OriginalFileName)" loading="lazy"
                             style="width: 100%; display: block;" />
                    </div>

                    <div style="padding: 0.625rem 0.75rem;">
                        <div style="font-size: 0.8125rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@image.OriginalFileName">
                            @(image.Name ?? image.OriginalFileName)
                        </div>
                        <div style="font-size: 0.6875rem; color: #6b7280; margin-top: 0.125rem;">
                            @if (image.IsVideo)
                            {
                                @image.Width<text>&times;</text>@image.Height
                                <text> &middot; </text>@image.FormattedDuration
                                <text> &middot; </text>@image.FormattedSize
                            }
                            else
                            {
                                @image.Width<text>&times;</text>@image.Height
                                <text> &middot; </text>@image.FormattedSize
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Load More ── *@
        @if (_nextCursor is not null)
        {
            <div style="display: flex; justify-content: center; margin-top: 1.25rem;">
                <RadzenButton Text="@(_loadingMore ? "Loading..." : "Load more")"
                              ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Small"
                              IsBusy="@_loadingMore"
                              Click="@(args => LoadMoreAsync())" />
            </div>
        }
    }
</div>

@* ── Delete folder confirmation overlay ── *@
@if (_folderToDelete is not null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000; display: flex; align-items: center; justify-content: center;"
         @onclick="() => _folderToDelete = null">
        <div style="background: #fff; border-radius: 0.75rem; padding: 1.5rem; max-width: 28rem; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.3);"
             @onclick:stopPropagation="true">
            <h3 style="margin: 0 0 0.5rem 0; font-size: 1rem; font-weight: 600; color: #1e293b;">Delete folder?</h3>
            <p style="margin: 0 0 1.25rem 0; font-size: 0.875rem; color: #64748b; line-height: 1.5;">
                This will permanently delete the folder <strong>@ChildFolderDisplayName(_folderToDelete)</strong> and all images inside it. This cannot be undone.
            </p>
            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                <RadzenButton Text="Cancel"
                              ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small"
                              Click="@(args => _folderToDelete = null)" />
                <RadzenButton Text="@(_deletingFolder ? "Deleting..." : "Delete folder")"
                              ButtonStyle="ButtonStyle.Danger"
                              Size="ButtonSize.Small"
                              IsBusy="@_deletingFolder"
                              Click="@(args => ConfirmDeleteFolderAsync())" />
            </div>
        </div>
    </div>
}
