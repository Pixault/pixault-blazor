@namespace Pixault.Blazor

<div style="--pxlt-accent: @AccentColor; width: 100%;">

    @* ── Folder selector (hidden in embedded mode) ── *@
    @if (InitialFolder is null)
    {
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
            <label style="font-size: 0.75rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Folder</label>
            @if (_folders.Count > 0)
            {
                <RadzenDropDown TValue="string?" @bind-Value="_selectedFolder"
                                Data="@_folderOptions" TextProperty="Text" ValueProperty="Value"
                                Placeholder="Root (no folder)"
                                AllowClear="true"
                                Style="flex: 1; max-width: 300px;" />
            }
            else
            {
                <RadzenTextBox @bind-Value="_selectedFolder"
                               Placeholder="e.g. portfolio/landscapes"
                               Style="flex: 1; max-width: 300px;" />
            }
        </div>
    }

    @* ── Drop zone ── *@
    <div style="position: relative; border: 2px dashed @(_isDragging ? "var(--pxlt-accent, #06b6d4)" : "#cbd5e1"); border-radius: 0.75rem; background: @(_isDragging ? "rgba(6, 182, 212, 0.05)" : "transparent"); padding: 0; transition: all 0.15s; cursor: pointer;"
         @ondragenter="HandleDragEnter"
         @ondragenter:preventDefault
         @ondragover:preventDefault
         @ondragleave="HandleDragLeave"
         @ondrop="HandleDragLeave">

        <InputFile OnChange="HandleFilesSelected"
                   multiple="@Multiple"
                   accept="@AcceptString"
                   style="position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; z-index: 1;" />

        @if (DropZoneContent is not null)
        {
            @DropZoneContent
        }
        else
        {
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 3rem 1.5rem; gap: 0.5rem; pointer-events: none;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                     style="width: 2.5rem; height: 2.5rem; color: var(--pxlt-accent, #06b6d4); margin-bottom: 0.25rem;">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="17 8 12 3 7 8" />
                    <line x1="12" y1="3" x2="12" y2="15" />
                </svg>
                <p style="margin: 0; font-size: 0.9375rem; text-align: center;">
                    @if (_isDragging)
                    {
                        <span>Drop to upload</span>
                    }
                    else
                    {
                        <span>Drop images here or <strong style="color: var(--pxlt-accent, #06b6d4);">click to browse</strong></span>
                    }
                </p>
                <p style="margin: 0; font-size: 0.8125rem; color: #6b7280;">
                    @AcceptHint &middot; Max @MaxSizeMb MB
                </p>
            </div>
        }
    </div>

    @* ── File list ── *@
    @if (_items.Count > 0)
    {
        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.75rem;">
            @foreach (var item in _items)
            {
                <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; border: 1px solid @FileCardBorderColor(item); border-radius: 0.625rem; background: @FileCardBgColor(item); transition: border-color 0.2s;">

                    @* Preview / icon *@
                    <div style="flex-shrink: 0; width: 3rem; height: 3rem; border-radius: 0.5rem; overflow: hidden; background: #f9fafb; display: flex; align-items: center; justify-content: center;">
                        @if (item.State == UploadState.Complete && ShowPreview && item.PreviewUrl is not null)
                        {
                            <img src="@item.PreviewUrl" alt="@item.FileName" loading="lazy"
                                 style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else if (item.IsSvg)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                 style="width: 1.5rem; height: 1.5rem; color: #6b7280;">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                <polyline points="14 2 14 8 20 8" />
                                <text x="7" y="17" fill="currentColor" stroke="none" font-size="6" font-weight="bold">SVG</text>
                            </svg>
                        }
                        else
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                                 style="width: 1.5rem; height: 1.5rem; color: #6b7280;">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                                <circle cx="8.5" cy="8.5" r="1.5" />
                                <polyline points="21 15 16 10 5 21" />
                            </svg>
                        }
                    </div>

                    @* Info *@
                    <div style="flex: 1; min-width: 0;">
                        <div style="font-size: 0.875rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.FileName">@item.FileName</div>
                        <div style="font-size: 0.75rem; color: #6b7280; display: flex; align-items: center; gap: 0.5rem; margin-top: 0.125rem;">
                            @item.FormattedSize
                            @if (item.State == UploadState.Complete && item.ImageId is not null)
                            {
                                <span style="font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.6875rem; background: #f9fafb; padding: 0.0625rem 0.375rem; border-radius: 4px;">@item.ImageId</span>
                            }
                        </div>

                        @if (item.State is UploadState.Uploading or UploadState.Validating)
                        {
                            <RadzenProgressBar Value="@item.Progress"
                                               ShowValue="false"
                                               Style="height: 4px; margin-top: 0.375rem;" />
                        }

                        @if (item.State == UploadState.Error)
                        {
                            <div style="font-size: 0.75rem; color: #ef4444; margin-top: 0.25rem;">@item.ErrorMessage</div>
                        }
                    </div>

                    @* Status / actions *@
                    <div style="flex-shrink: 0; display: flex; align-items: center; gap: 0.25rem;">
                        @if (item.State == UploadState.Complete)
                        {
                            <svg viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"
                                 style="width: 1.25rem; height: 1.25rem;">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                <polyline points="22 4 12 14.01 9 11.01" />
                            </svg>
                        }
                        else if (item.State == UploadState.Error)
                        {
                            <RadzenButton Icon="refresh"
                                          ButtonStyle="ButtonStyle.Light"
                                          Size="ButtonSize.Small"
                                          title="Retry"
                                          Click="@(args => RetryUploadAsync(item))" />
                        }

                        <RadzenButton Icon="close"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      title="Remove"
                                      Click="@(args => RemoveItem(item))" />
                    </div>
                </div>
            }
        </div>
    }
</div>
